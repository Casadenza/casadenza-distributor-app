# ==============================
# DATABASE (Postgres)
# ==============================
# Used by Prisma + app runtime
DATABASE_URL="postgresql://postgres:1234@localhost:5432/casadenza?schema=public"

# Used by Prisma for migrations / direct connection (recommended to keep same locally)
DIRECT_URL="postgresql://postgres:1234@localhost:5432/casadenza?schema=public"


# ==============================
# AUTH (JWT cookie session)
# ==============================
# Used by lib/serverSession.ts + middleware.ts
# Must be strong, 32+ chars
SESSION_SECRET="change_me_super_secret_32_chars_min"


# ==============================
# STORAGE
# ==============================
# local  = saves files to /storage/* (best for local dev)
# cloud  = Cloudinary (required for Vercel production)
STORAGE_MODE="local"


# ==============================
# CLOUDINARY (only if STORAGE_MODE=cloud)
# ==============================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""